{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd KWU-Pegasus-server && npm install"
  },
  "deploy": {
    "startCommand": "cd KWU-Pegasus-server && node migrate.js && node server.js",
    "restartPolicyType": "ON_FAILURE"
  }
}
