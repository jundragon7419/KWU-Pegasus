# ================================================================
# 환경변수 템플릿 - 이 파일을 복사해 .env로 저장 후 값을 채워주세요
# cp .env.example .env
# ================================================================

# 서버 포트
PORT=3001

# MySQL 데이터베이스 연결 정보
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=kwu_pegasus

# JWT 서명에 사용되는 비밀 키 (임의의 긴 문자열로 설정)
JWT_SECRET=

# 허용할 프론트엔드 주소 (CORS)
# 로컬 개발: http://localhost:5173
# 배포 시: 실제 도메인으로 변경
CORS_ORIGIN=http://localhost:5173
